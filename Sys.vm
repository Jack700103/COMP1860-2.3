function Sys.min 0
    push argument 0  
    push argument 1  
    lt              
    if-true   MIN_FIRST
    if-false  MIN_SECOND
MIN_FIRST:
    push argument 0  
    return
MIN_SECOND:
    push argument 1  
    return


function Sys.max 0
    push argument 0  
    push argument 1  
    gt              
    if-true   MAX_FIRST
    if-false  MAX_SECOND
MAX_FIRST:
    push argument 0  
    return
MAX_SECOND:
    push argument 1  
    return


function Sys.range 2
    push argument 1  
    push constant 1
    eq              
    if-true  RANGE_ZERO

    push argument 0  
    pop pointer 0    
    push constant 0
    pop local 0      
    push constant 0
    pop local 1      
    
    push local 1     
    push local 0     
    sub             
    return
RANGE_ZERO:
    push constant 0  
    return
