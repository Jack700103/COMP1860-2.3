function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto ARG0_LESS_THAN_ARG1
    push argument 1
    return
(ARG0_LESS_THAN_ARG1)
    push argument 0
    return


function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto ARG0_GREATER_THAN_ARG1
    push argument 1
    return
(ARG0_GREATER_THAN_ARG1)
    push argument 0
    return


function Sys.range 2
    push argument 1
    push constant 2
    lt
    if-goto RETURN_ZERO

    push argument 0
    pop pointer 1
    push that 0
    pop local 0
    push that 0
    pop local 1

    push constant 1
    pop temp 0

(LOOP)
    push temp 0
    push argument 1
    lt
    if-goto PROCESS_ELEMENT
    goto END_LOOP

(PROCESS_ELEMENT)
    push argument 0
    push temp 0
    add
    pop pointer 1

    push local 0
    push that 0
    call Sys.min 2   
    pop local 0

    push local 1
    call Sys.max 2
    pop local 1

    push temp 0
    push constant 1
    add
    pop temp 0

    goto LOOP

(END_LOOP)
    push local 1
    push local 0
    sub
    return

(RETURN_ZERO)
    push constant 0
    return



function Sys.init 0
    call Sys.range 2
label WHILE
    goto WHILE