function Sys.max 0
    push argument 0     
    push argument 1     
    gt                 
    if-true   GT_TRUE  
    if-false  GT_FALSE
label GT_TRUE
    push argument 0     
    return
label GT_FALSE
    push argument 1     
    return


function Sys.min 0
    push argument 0     
    push argument 1     
    lt                 
    if-true   LT_TRUE  
    if-false  LT_FALSE
label LT_TRUE
    push argument 0    
    return
label LT_FALSE
    push argument 1     
    return



function Sys.range 2
    push argument 1     
    push constant 1
    eq                 
    if-true  RANGE_ZERO
    push argument 0     
    call Sys.min 1     
    pop local 0         
    push argument 0     
    call Sys.max 1     
    pop local 1         
    push local 1        
    push local 0        
    sub                
    return
label RANGE_ZERO
    push constant 0     
    return
