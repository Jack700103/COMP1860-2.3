function Sys.min 0
    push argument 0
    push argument 1
    lt
    if-goto MIN_IS_ARG0
    push argument 1
    return
(MIN_IS_ARG0)
    push argument 0
    return

function Sys.max 0
    push argument 0
    push argument 1
    gt
    if-goto MAX_IS_ARG0
    push argument 1
    return
(MAX_IS_ARG0)
    push argument 0
    return

function Sys.range 2
    push argument 1
    push constant 0
    sub
    if-gt INIT_LOOP
    push constant 0
    return
(INIT_LOOP)
    push argument 0
    pop pointer 0
    push this 0
    pop local 0
    push this 0
    pop local 1
    push constant 1
    pop local 2
(LOOP)
    push local 2
    push argument 1
    sub
    if-gte END_LOOP
    push argument 0
    push local 2
    add
    pop pointer 0
    push this 0
    pop local 3
    push local 3
    push local 0
    call Sys.min 2
    pop local 0
    push local 3
    push local 1
    call Sys.max 2
    pop local 1
    push local 2
    push constant 1
    add
    pop local 2
    goto LOOP
(END_LOOP)
    push local 1
    push local 0
    sub
    return

function Sys.init 0
    push constant 256
    pop pointer 1
    push that 0
    push that 1
    call Sys.range 2
    push constant 256
    pop pointer 1
    pop that 0
(WHILE)
    goto WHILE
